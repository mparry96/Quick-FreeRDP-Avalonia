<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Quick_FreeRDP.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Quick_FreeRDP.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        WindowStartupLocation="CenterScreen"
        Width="500" Height="560"
        MaxWidth="900" MaxHeight="800"
        MinWidth="300" MinHeight="300"
        Title="Quick_FreeRDP">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel />
    </Design.DataContext>
   
    
    <Grid Margin="20,20,20,20" ColumnDefinitions="*">
        
        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
              RowSpacing="12"
              ColumnSpacing="20"
              Margin="5"
              HorizontalAlignment="Stretch">


            <ComboBox Grid.Row="0" Grid.Column="0" SelectedIndex="0"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch"
                      Grid.ColumnSpan="2"
                      SelectedItem="{Binding SelectedRdpItem}"
                      DisplayMemberBinding="{Binding Name}"
                      ItemsSource="{Binding RdpItems}">
            </ComboBox>

            <Button Grid.Column="0" Grid.Row="1"
                    Background="Red"
                    FontWeight="Bold"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    IsEnabled="{Binding DeleteAndLaunchEnabled}"
                    Command="{Binding Delete}">
                Delete Entry
            </Button>

            <Button Grid.Column="1" Grid.Row="1"
                    Background="ForestGreen"
                    FontWeight="Bold"
                    HorizontalContentAlignment="Center"
                    HorizontalAlignment="Stretch"
                    IsEnabled="{Binding DeleteAndLaunchEnabled}"
                    Command="{Binding Launch}">
                Launch
            </Button>

            <Expander Header="RDP Details" Margin="0,20,0,0"
                      HorizontalAlignment="Stretch"
                      IsExpanded="True" Grid.Row="2" Grid.ColumnSpan="2">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                      ColumnDefinitions="Auto,*"
                      ColumnSpacing="26"
                      RowSpacing="14"
                      Margin="0,10,0,0">

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               VerticalAlignment="Center">
                        RDP Name
                    </TextBlock>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding NewRdpItem.Name}" />
                    
                    <TextBlock Grid.Row="1" Grid.Column="0"
                               VerticalAlignment="Center">
                        User Name
                    </TextBlock>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{Binding NewRdpItem.UserName}" />

                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center">IP Address</TextBlock>
                    <TextBox Grid.Row="2" Grid.Column="1"
                             Text="{Binding NewRdpItem.IpAddress}" />

                    <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center">Resolution</TextBlock>
                    <Grid Grid.Row="3" Grid.Column="1" ColumnDefinitions="*,*"
                          ColumnSpacing="20"
                          HorizontalAlignment="Stretch">
                        <TextBox Grid.Column="0" Text="{Binding NewRdpItem.ResolutionWidth}" />
                        <TextBox Grid.Column="1" Text="{Binding NewRdpItem.ResolutionHeight}" />
                    </Grid>

                    <TextBlock Grid.Row="4"
                               Grid.Column="0"
                               VerticalAlignment="Center">
                        Full Screen
                    </TextBlock>
                    <CheckBox Grid.Row="4"
                              Grid.Column="1"
                              VerticalAlignment="Top"
                              IsChecked="{Binding NewRdpItem.FullScreenBool}">
                    </CheckBox>

                    <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center">Floatbar</TextBlock>
                    <CheckBox Grid.Row="5" Grid.Column="1"
                              VerticalAlignment="Top"
                              IsChecked="{Binding NewRdpItem.FloatBarBool}">
                    </CheckBox>


                    <Button Grid.Column="0" Grid.Row="6"
                            Background="CadetBlue"
                            FontWeight="Bold"
                            Grid.ColumnSpan="2"
                            HorizontalAlignment="Right"
                            Padding="50,5,50,5"
                            Margin="0,10,10,0"
                            IsEnabled="{Binding SaveEnabled}"
                            Command="{Binding SaveDetails}">
                        Save
                    </Button>

                </Grid>
            </Expander>

        </Grid>
    </Grid>

</Window>