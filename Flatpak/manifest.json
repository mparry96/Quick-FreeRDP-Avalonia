{
  "app-id": "com.example.QuickFreeRDP",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "23.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "Quick-FreeRDP",
  "finish-args": [
    "--share=network",
    "--socket=x11",
    "--socket=wayland",
    "--device=dri"
  ],
  "add-extensions": {
    "org.freedesktop.Platform.ffmpeg-full": {
      "version": "23.08",
      "directory": "lib/ffmpeg",
      "add-ld-path": ".",
      "no-autodownload": false
    }
  },
  "cleanup-commands": [
    "mkdir -p ${FLATPAK_DEST}/lib/ffmpeg"
  ],
  "modules": [
    {
      "name": "libusb",
      "buildsystem": "autotools",
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/libusb/libusb/releases/download/v1.0.26/libusb-1.0.26.tar.bz2",
          "sha256": "12ce7a61fc9854d1d2a1ffe095f7b5fac19ddba095c259e6067a46500381b5a5"
        }
      ]
    },
    {
      "name": "freerdp",
      "buildsystem": "cmake-ninja",
      "config-opts": [
        "-DWITH_X11=ON",
        "-DWITH_CLIENT_SDL=OFF",
        "-DWITH_WAYLAND=ON"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/FreeRDP/FreeRDP/archive/refs/tags/2.11.5.tar.gz",
          "sha256": "8c2300545cd360889ac5420ba5c201532403b800188368c5b28bde9c9e3eec85"
        }
      ]
    },
    {
      "name": "quick-freerdp",
      "buildsystem": "simple",
      "build-commands": [
        "mkdir -p /app/bin",
        "mkdir -p /app/share/applications",
        "mkdir -p /app/share/icons/hicolor/256x256/apps",
        "cp -r ./* /app/bin/",
        "chmod +x /app/bin/Quick-FreeRDP",
        "install -Dm644 Quick-FreeRDP.desktop /app/share/applications/com.example.QuickFreeRDP.desktop",
        "install -Dm644 QuickResolution.png /app/share/icons/hicolor/256x256/apps/com.example.QuickFreeRDP.png"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "../Quick-FreeRDP/bin/Release/net10.0/linux-x64/publish"
        },
        {
          "type": "file",
          "path": "Quick-FreeRDP.desktop"
        },
        {
          "type": "file",
          "path": "QuickResolution.png"
        }
      ]
    }
  ]
}