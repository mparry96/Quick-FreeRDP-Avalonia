[Application]
name=com.example.QuickFreeRDP
runtime=org.freedesktop.Platform/x86_64/23.08
sdk=org.freedesktop.Sdk/x86_64/23.08
command=Quick-FreeRDP

[Context]
shared=network;
sockets=x11;wayland;
devices=dri;

[Extension com.example.QuickFreeRDP.Debug]
directory=lib/debug
autodelete=true
no-autodownload=true

[Build]
built-extensions=com.example.QuickFreeRDP.Debug;