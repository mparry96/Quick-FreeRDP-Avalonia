{
  "app-id": "com.mparry96.QuickRDP",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "23.08",
  "sdk": "org.freedesktop.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.dotnet8"
  ],
  "command": "Quick-FreeRDP",
  "finish-args": [
    "--share=network",
    "--socket=x11",
    "--socket=wayland",
    "--device=dri"
  ],
  "add-extensions": {
    "org.freedesktop.Platform.ffmpeg-full": {
      "version": "23.08",
      "directory": "lib/ffmpeg",
      "add-ld-path": ".",
      "no-autodownload": false
    }
  },
  "cleanup-commands": [
    "mkdir -p ${FLATPAK_DEST}/lib/ffmpeg"
  ],
  "modules": [
    {
      "name": "libusb",
      "buildsystem": "autotools",
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/libusb/libusb/releases/download/v1.0.26/libusb-1.0.26.tar.bz2",
          "sha256": "12ce7a61fc9854d1d2a1ffe095f7b5fac19ddba095c259e6067a46500381b5a5"
        }
      ]
    },
    {
      "name": "freerdp",
      "buildsystem": "cmake-ninja",
      "config-opts": [
        "-DWITH_X11=ON",
        "-DWITH_CLIENT_SDL=OFF",
        "-DWITH_WAYLAND=ON"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/FreeRDP/FreeRDP/archive/refs/tags/2.11.5.tar.gz",
          "sha256": "8c2300545cd360889ac5420ba5c201532403b800188368c5b28bde9c9e3eec85"
        }
      ]
    },
    {
      "name": "quick-freerdp",
      "buildsystem": "simple",
      "build-options": {
        "append-path": "/usr/lib/sdk/dotnet8/bin",
        "env": {
          "DOTNET_ROOT": "/usr/lib/sdk/dotnet8",
          "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
          "DOTNET_NOLOGO": "1"
        },
        "build-args": [
          "--share=network"
        ]
      },
      "build-commands": [
        "dotnet restore Quick-FreeRDP/Quick-FreeRDP.csproj",
        "dotnet publish Quick-FreeRDP/Quick-FreeRDP.csproj -c Release -r linux-x64 --self-contained true -p:PublishSingleFile=true -f net8.0 -o /app/build",
        "install -Dm755 /app/build/Quick-FreeRDP /app/bin/Quick-FreeRDP",
        "mkdir -p /app/share/applications /app/share/metainfo /app/share/icons/hicolor/256x256/apps",
        "cp -r Flatpak/* /app/share/",
        "install -Dm644 Flatpak/com.mparry96.QuickRDP.png /app/share/icons/hicolor/256x256/apps/com.mparry96.QuickRDP.png",
        "install -Dm644 Flatpak/com.mparry96.QuickRDP.desktop /app/share/applications/com.mparry96.QuickRDP.desktop",
        "install -Dm644 Flatpak/com.mparry96.QuickRDP.metainfo.xml /app/share/metainfo/com.mparry96.QuickRDP.metainfo.xml"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/mparry96/Quick-FreeRDP-Avalonia.git",
          "branch": "main"
        }
      ]
    }
  ]
}