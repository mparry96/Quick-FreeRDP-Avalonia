<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.mparry96.QuickRDP</id>

  <name>Quick FreeRDP</name>

  <summary>Simple graphical FreeRDP launcher built with Avalonia</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <developer id="github.com/mparry">
    <name>Martin Parry</name>
  </developer>

  <description>
    <p>
      Quick FreeRDP is a lightweight graphical frontend for FreeRDP,
      designed to make launching remote desktop sessions simple and fast.
    </p>

    <p>Features include:</p>
    <ul>
      <li>Saved RDP connections</li>
      <li>Custom resolutions</li>
      <li>Fullscreen support</li>
      <li>Simple Avalonia UI</li>
    </ul>
  </description>

  <launchable type="desktop-id">
    com.mparry96.QuickRDP.desktop
  </launchable>

  <screenshots>
    <screenshot type="default">
      <image>
        https://raw.githubusercontent.com/mparry96/Quick-FreeRDP-Avalonia/main/com.mparry96.QuickRDP/ScreenShotForMetainfo.png
      </image>
    </screenshot>
  </screenshots>

  <url type="homepage">
    https://github.com/mparry96/Quick-FreeRDP-Avalonia
  </url>

  <url type="bugtracker">
    https://github.com/mparry96/Quick-FreeRDP-Avalonia/issues
  </url>

  <content_rating type="oars-1.1"/>

  <releases>
    <release version="1.0.0" date="2026-05-29"/>
  </releases>

  <categories>
    <category>Network</category>
    <category>RemoteAccess</category>
  </categories>
</component>