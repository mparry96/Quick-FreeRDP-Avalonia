# Flatpak build output
build-dir/
.flatpak-builder/

# Ignore Rider and IntelliJ IDEA-specific files
.idea/
*.iml

# Ignore build output directories (common in .NET projects)
bin/
obj/

# Ignore temporary files generated by .NET Core / .NET SDK
.vscode/
.vs/

# Ignore user-specific files and folders (may contain IDE-specific configurations)
# This includes VS Code, Visual Studio settings, Rider settings, etc.
*.user
*.userosscache
*.suo
*.userprefs
.vscode/

# Avalonia (platform-specific generated files)
# Avalonia generates some platform-specific files during build or runtime
# Add any specific platform file types here if necessary
*.nupkg
*.snupkg
*.pdb
*.dll
*.exe

# Ignore package-related files
# Ignore packages directory generated by .NET Core / .NET SDK
/packages/
project.lock.json
project.fragment.lock.json

# Ignore temporary files created by the OS
.DS_Store
Thumbs.db

# Ignore IDE workspace files (e.g., JetBrains Rider's workspace files)
.idea/

# Ignore NuGet package cache
.nuget/

# Ignore logs generated during runtime or debugging
*.log

# Ignore generated files from Visual Studio, Rider, or MSBuild tools
# These files should be ignored across the board
# These are typically generated files during build or publishing processes
publish/
artifacts/
bin/
obj/

# Ignore Visual Studio for Mac and Rider-generated directories
.vscode/

# Ignore Windows Installer/Deployment Files
*.cab
*.msi
*.msm
*.msp

# Ignore other IDE-specific files
*.suo
*.user
.idea/*

# Ignore other platform-specific files (e.g., macOS, Windows, Linux)
# Linux system files
*~
# MacOS system files
.DS_Store

# Ignore platform-dependent files and directories (e.g., build artifacts)
# You can add other OS-specific patterns here if you need
*.log
