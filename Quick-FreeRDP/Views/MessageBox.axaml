<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" Width="300" Height="200"
        x:Class="Quick_FreeRDP.Views.MessageBox"
        WindowDecorations="None"
        CanResize="False"
        KeyDown="InputElement_OnKeyDown"
        CanMaximize="False"
        CanMinimize="False"
        Title="">

    <Border BorderBrush="Gray" BorderThickness="5">

        <Grid ColumnDefinitions="*" RowDefinitions="*,*"
              Margin="20"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              RowSpacing="30">


            <TextBox Grid.Row="0" Grid.Column="0"
                     BorderThickness="0"
                     Name="MessageContent"
                     PlaceholderText="This is a placeholder message, the real text goes here etc."
                     TextWrapping="Wrap"
                     IsReadOnly="True"
                     HorizontalAlignment="Center">
                
            </TextBox>

            <Button Grid.Row="1" Grid.Column="0"
                    x:Name="CloseButton"
                    Background="CadetBlue"
                    HorizontalAlignment="Center"
                    Command="{Binding $parent[Window].Close}">
                Close
            </Button>

        </Grid>

    </Border>
</Window>